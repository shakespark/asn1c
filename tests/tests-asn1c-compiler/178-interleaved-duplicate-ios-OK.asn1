-- OK: Everything is fine

-- Regression test for review-flagged index misalignment between the
-- presence enum, the union members, the asn_TYPE_member_t table and the
-- tag2el map of a table-constrained open type CHOICE, when an Information
-- Object Set repeats the same anonymous &Type across genuinely
-- non-adjacent rows (a different type sits between the two occurrences).
--
-- Minimal repro: { INTEGER IDENTIFIED BY 1 } | { BOOLEAN IDENTIFIED BY 2 }
-- | { INTEGER IDENTIFIED BY 3 }. Before the suffix-based fix, the presence
-- enum alone skipped the second INTEGER (leaving just value_PR_INTEGER,
-- value_PR_BOOLEAN), while the member table, tag2el map and the runtime
-- row selector still counted all three rows: decoding id=3 (the second
-- INTEGER row) picked present=3, an enumerator the truncated 2-entry enum
-- did not even have. The runtime encode/decode assertions for ids 1/2/3
-- are registered as tests/tests-c-compiler/check-src/check-178.c.

-- iso.org.dod.internet.private.enterprise (1.3.6.1.4.1)
-- .spelio.software.asn1c.test (9363.1.5.1)
-- .178

ModuleInterleavedDuplicateIOS
	{ iso org(3) dod(6) internet (1) private(4) enterprise(1)
		spelio(9363) software(1) asn1c(5) test(1) 178 }
	DEFINITIONS AUTOMATIC TAGS ::=
BEGIN

    P ::= CLASS {
        &id    INTEGER (0..255) UNIQUE,
        &Type
    } WITH SYNTAX { &Type IDENTIFIED BY &id }

    Objs P ::= {
        { INTEGER IDENTIFIED BY 1 } |
        { BOOLEAN IDENTIFIED BY 2 } |
        { INTEGER IDENTIFIED BY 3 }
    }

    T ::= SEQUENCE {
        id     P.&id({Objs}),
        value  P.&Type({Objs}{@id})
    }

END
